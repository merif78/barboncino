generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum Sex {
  MASCHIO
  FEMMINA
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(USER)
  bio           String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  dogs          Dog[]
  events        Event[]
  galleries     Gallery[]
  diaries       Diary[]
  articles      Article[]
  comments      Comment[]
  likes         Like[]
  notifications Notification[]
  documents     Document[]
  foodLogs      FoodLog[]
  walks         Walk[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Dog {
  id          String    @id @default(cuid())
  name        String
  photo       String?
  birthDate   DateTime?
  breed       String    @default("Barboncino")
  sex         Sex?
  weight      Float?
  height      Float?
  color       String?
  microchip   String?
  vet         String?
  insurance   String?
  allergies   String?
  medications String?
  conditions  String?
  character   String?
  notes       String?
  userId      String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  events         Event[]
  weightHistory  WeightHistory[]
  galleries      Gallery[]
  diaries        Diary[]
  documents      Document[]
  foodLogs       FoodLog[]
  walks          Walk[]
}

model Event {
  id          String    @id @default(cuid())
  title       String
  description String?
  date        DateTime
  time        String?
  category    String    @default("altro")
  priority    String    @default("normale")
  color       String    @default("#e2436c")
  reminder    Boolean   @default(false)
  recurrence  String?
  notes       String?
  dogId       String
  userId      String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  dog  Dog  @relation(fields: [dogId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WeightHistory {
  id        String   @id @default(cuid())
  date      DateTime @default(now())
  weight    Float
  height    Float?
  dogId     String
  createdAt DateTime @default(now())

  dog Dog @relation(fields: [dogId], references: [id], onDelete: Cascade)
}

model Gallery {
  id        String   @id @default(cuid())
  url       String
  caption   String?
  dogId     String
  userId    String
  createdAt DateTime @default(now())

  dog  Dog  @relation(fields: [dogId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Diary {
  id        String   @id @default(cuid())
  date      DateTime @default(now())
  content   String
  mood      String?
  dogId     String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  dog  Dog  @relation(fields: [dogId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Article {
  id          String    @id @default(cuid())
  title       String
  subtitle    String?
  slug        String    @unique
  content     String    @db.Text
  imageUrl    String?
  authorId    String
  categoryId  String?
  readingTime Int       @default(5)
  publishedAt DateTime  @default(now())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  author   User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id])
  comments Comment[]
  likes    Like[]
}

model Category {
  id       String    @id @default(cuid())
  name     String    @unique
  slug     String    @unique
  articles Article[]
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  articleId String
  userId    String
  createdAt DateTime @default(now())

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Like {
  id        String   @id @default(cuid())
  articleId String
  userId    String
  createdAt DateTime @default(now())

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([articleId, userId])
}

model Notification {
  id        String   @id @default(cuid())
  message   String
  read      Boolean  @default(false)
  userId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Document {
  id        String   @id @default(cuid())
  name      String
  url       String
  type      String   @default("altro")
  dogId     String
  userId    String
  createdAt DateTime @default(now())

  dog  Dog  @relation(fields: [dogId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FoodLog {
  id        String   @id @default(cuid())
  date      DateTime @default(now())
  brand     String?
  grams     Float?
  snacks    String?
  water     Float?
  dogId     String
  userId    String
  createdAt DateTime @default(now())

  dog  Dog  @relation(fields: [dogId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Walk {
  id        String   @id @default(cuid())
  date      DateTime @default(now())
  duration  Int?
  distance  Float?
  notes     String?
  dogId     String
  userId    String
  createdAt DateTime @default(now())

  dog  Dog  @relation(fields: [dogId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
